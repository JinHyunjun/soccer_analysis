# 무료 계정: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_COMPETITIONS=WC,PL,PD,BL1,SA,FL1

# 무료 계정: https://dashboard.api-football.com/register
# 확정 이적 조회는 추적할 team id가 필요합니다.
API_FOOTBALL_KEY=
API_FOOTBALL_TEAM_IDS=

# 기본 BBC Sport Football RSS 외에 추가할 RSS URL(쉼표 구분)
EXTRA_RSS_FEEDS=

# API 키가 없을 때 화면 구조를 확인할 명시적 샘플 데이터
ENABLE_DEMO_DATA=true
